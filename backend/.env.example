DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=wavehub
DATABASE_PASSWORD=wavehubpass
DATABASE_NAME=wavehubdb
PORT=4000
CORS_ORIGIN=http://localhost:3000
TYPEORM_SYNC=true
NODE_ENV=development

# Required in production (throws at boot if unset there). Falls back to an insecure dev-only
# default locally so `npm run start:dev` and CI don't need it configured — see auth.module.ts.
JWT_SECRET=

# Used to build links in verification/password-reset emails.
FRONTEND_URL=http://localhost:3000

# This backend's own publicly-reachable base URL — used to build the BOG callback URL
# (${BACKEND_PUBLIC_URL}/payments/bog/callback). Must be HTTPS and reachable from BOG's servers in
# any real deployment (a local dev value won't actually receive callbacks unless tunneled).
BACKEND_PUBLIC_URL=http://localhost:4000

# Bank of Georgia e-commerce API credentials (WaveCoin top-up). Required for /payments/bog/* to
# work; that endpoint returns 503 if these are unset. See backend/src/payments/CLAUDE.md.
BOG_CLIENT_ID=
BOG_CLIENT_SECRET=
# Optional overrides — only set these to point at a BOG sandbox/non-default environment, or if BOG
# rotates the callback-signing public key (see bog-signature.util.ts for the current default).
# BOG_OAUTH_URL=
# BOG_ORDERS_URL=
# BOG_CALLBACK_PUBLIC_KEY=
